# H-Beam Agent — 部署環境變數範本
# 用法:cp .env.example .env,然後填入實際值
#
# ─────────────────────────────────────────────────────────
# GCP 基本設定
# ─────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project
GOOGLE_CLOUD_PROJECT=your-gcp-project

# Agent Runtime 部署區域(台灣)
GCP_REGION=asia-east1

# ─────────────────────────────────────────────────────────
# Gemini 3 Global Endpoint(必須 — 詳見 LLM_Global_Endpoint.md)
# Agent Runtime 部署在 asia-east1,但 Gemini 模型呼叫一定要走 global,
# 否則 gemini-3-flash-preview 回 404 NOT_FOUND。
# ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# ─────────────────────────────────────────────────────────
# 後端 H-Beam Quote Service URL
# 本地:http://localhost:8080(docker run h-beam-quote)
# 雲端:Cloud Run 部署後的 URL
# ─────────────────────────────────────────────────────────
QUOTE_API_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────
# Agent Runtime 部署設定
# 注意:agents-cli deploy 走 inline source-packages 模式,
# tarball 直接放進 Vertex AI API 請求 body,**不需 staging bucket**。
# ─────────────────────────────────────────────────────────
SERVICE_ACCOUNT=h-beam-agent@your-gcp-project.iam.gserviceaccount.com

# ─────────────────────────────────────────────────────────
# Memory Bank(由 Agent Runtime 自動處理,部署後自動可用)
# ─────────────────────────────────────────────────────────
AGENT_ENGINE_ID=

# ─────────────────────────────────────────────────────────
# Observability — Cloud Trace + Cloud Logging(自動接線)
# ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Prompt/Response 內容紀錄模式
# - "false"(預設): 只收 metadata
# - "NO_CONTENT":  metadata + 結構但不含實際 prompt/response 文字(推薦,避免 PII)
# - "true":       完整內容(注意 PII)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT

# 若要把 prompt/response 上傳到 GCS(可選):
# LOGS_BUCKET_NAME=your-gcp-project-h-beam-logs
# GENAI_TELEMETRY_PATH=completions
